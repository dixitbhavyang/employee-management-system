# ================================================
# Employee Management System - .gitignore
# Full-Stack (.NET + Angular)
# ================================================

# ========================================
# BACKEND (.NET Core)
# ========================================

## User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

## Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

## Visual Studio cache/options
.vs/
.vscode/
*.vsidx
*.vssscc

## NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

## Test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
coverage*.json
coverage*.xml
*.coverage
*.coveragexml

## Entity Framework Migrations (keep structure, ignore autogenerated)
# **/Migrations/*.cs
# !**/Migrations/*_Initial.cs

## Rider
.idea/
*.sln.iml

## User secrets
secrets.json
appsettings.Development.json
appsettings.*.json
!appsettings.json
!appsettings.Production.json

## Database
*.mdf
*.ldf
*.ndf

# ========================================
# FRONTEND (Angular)
# ========================================

## Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

## IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

## IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

## System Files
.DS_Store
Thumbs.db

## Angular Build
/dist
/tmp
/out-tsc
/bazel-out

## Angular Cache
.angular/

## Environment files (keep template, ignore actual)
# src/environments/environment.ts
# src/environments/environment.prod.ts

# ========================================
# GENERAL
# ========================================

## OS files
*.swp
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

## Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

## Temporary files
*.tmp
*.temp
tmp/
temp/

## Documentation
# /docs/_build/

## Package manager
.pnpm-debug.log
package-lock.json
yarn.lock
pnpm-lock.yaml

# ========================================
# SENSITIVE DATA (NEVER COMMIT!)
# ========================================

## Connection Strings
**/appsettings.Development.json
**/appsettings.Staging.json
ConnectionStrings.config

## API Keys
.env
.env.local
.env.*.local
secrets/
*.secret

## Certificates
*.pfx
*.p12
*.key
*.pem
*.crt

## Database backups
*.bak
*.sql.backup

# ========================================
# KEEP THESE (explicitly)
# ========================================

!.gitkeep
!README.md
!LICENSE
